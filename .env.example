# ============================================================
# TABBY MEME BANK - Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to Git!
# ============================================================

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
HUMANIZE_MODEL=claude-sonnet-4-5

# --- MSSQL ---
MSSQL_SERVER=TABBY\SQLEXPRESS
MSSQL_DATABASE=SophiaDB
MSSQL_USER=Sophia
MSSQL_PASSWORD=your_mssql_password_here

# --- BSC Chain ---
BSC_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/your_key/
TABBY_CONTRACT_ADDRESS=0x319558c8aD708dc42f45ab70eADA4750d6c942d7
TABBY_DECIMALS=18

# --- Twitter API ---
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_KOL_LIST=your_kol_list

# --- Google Gemini ---
GOOGLE_API_KEY=your_google_api_key

# --- Sophia Wallet (NEVER expose real private keys!) ---
SOPHIA_BSC_ADDRESS=0xYourSophiaBSCAddress
SOPHIA_BSC_PRIVATE_KEY=your_bsc_private_key_here
SOPHIA_SOL_ADDRESS=YourSolanaAddress
SOPHIA_SOL_PRIVATE_KEY=your_sol_private_key_here

# --- App Config ---
APP_SECRET_KEY=generate_a_random_secret_key_here
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
